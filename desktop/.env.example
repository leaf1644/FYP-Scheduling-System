# Desktop AI configuration template
#
# How to use for the packaged exe:
# 1. Copy this file to the same folder as FYP Scheduling System 0.1.0.exe
# 2. Rename the copied file to .env
# 3. Fill in your real API key values

# Supported values: google-gemini, hkbu-gemini
AI_PROVIDER=google-gemini

# Google Gemini configuration
GOOGLE_GEMINI_API_KEY=your_google_api_key_here
GOOGLE_GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Backward-compatible aliases
GEMINI_API_KEY=
GEMINI_MODEL=

# HKBU GenAI configuration
HKBU_GENAI_API_KEY=
HKBU_GENAI_BASE_URL=https://genai.hkbu.edu.hk/api/v0/rest
HKBU_GENAI_DEPLOYMENT=gemini-2.5-flash