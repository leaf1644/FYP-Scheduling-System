{
  "name": "fyp-scheduler-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Isolated desktop packaging project for the FYP Scheduling System",
  "author": "leaf1644",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.leaf1644.fypscheduler",
    "productName": "FYP Scheduling System",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "local-api.cjs"
    ],
    "extraResources": [
      {
        "from": "app-dist",
        "to": "app-dist"
      },
      {
        "from": "resources/python-runtime",
        "to": "python-runtime"
      },
      {
        "from": "resources/server",
        "to": "server"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "asar": true
  }
}